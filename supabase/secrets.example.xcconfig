// QuaraMoney — Supabase configuration TEMPLATE
//
// HOW TO USE:
//   1. Copy this file to `secrets.local.xcconfig` (same folder).
//   2. Paste your project URL and the `anon` / publishable key below.
//   3. `secrets.local.xcconfig` is gitignored — it will NOT be committed.
//
// ONLY the anon / publishable key goes here. NEVER put the service_role
// (secret) key in this file or anywhere in the app.

SUPABASE_URL = https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY = your_anon_or_publishable_key_here
